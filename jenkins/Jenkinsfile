pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 15, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    environment {
        IMAGE      = 'jkypch-web:latest'
        PROJECT    = 'jkypch'
        COMPOSE    = "docker compose -f /workspace/docker-compose.yml -p ${PROJECT}"
    }

    stages {

        stage('Build Image') {
            steps {
                echo "Building Docker image from /workspace/web"
                sh 'docker build -t ${IMAGE} /workspace/web'
            }
        }

        stage('Determine Slots') {
            steps {
                script {
                    def conf = readFile("/nginx-conf/web-active.conf")
                    env.ACTIVE   = conf.contains('web-blue') ? 'blue' : 'green'
                    env.INACTIVE = env.ACTIVE == 'blue' ? 'green' : 'blue'
                    echo "▶ Active=${env.ACTIVE}  →  Deploy to=${env.INACTIVE}"
                }
            }
        }

        stage('Start Inactive Slot') {
            steps {
                script {
                    def inactive = env.INACTIVE
                    // 기존 컨테이너 강제 정리 후 Compose로 기동
                    sh """
                        ${env.COMPOSE} --profile deploy rm -sf web-${inactive} 2>/dev/null || true
                        ${env.COMPOSE} --profile deploy up -d web-${inactive}
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def inactive = env.INACTIVE
                    echo "Waiting for web-${inactive}:8080/actuator/health ..."
                    timeout(time: 5, unit: 'MINUTES') {
                        waitUntil(initialRecurrencePeriod: 10000, quiet: true) {
                            def code = sh(
                                script: "curl -sf http://web-${inactive}:8080/actuator/health",
                                returnStatus: true
                            )
                            return code == 0
                        }
                    }
                    echo "✓ Health check passed for web-${inactive}"
                }
            }
        }

        stage('Switch Traffic') {
            steps {
                script {
                    def inactive = env.INACTIVE
                    def confContent = "map \$host \$web_backend {\n    default \"web-${inactive}:8080\";\n}\n"
                    writeFile file: "/nginx-conf/web-active.conf", text: confContent
                    sh """
                        docker exec ${env.PROJECT}-nginx-1 nginx -t && \
                        docker exec ${env.PROJECT}-nginx-1 nginx -s reload
                    """
                    echo "✓ Traffic switched to web-${inactive}"
                }
            }
        }

        stage('Stop Old Slot') {
            steps {
                script {
                    def active = env.ACTIVE
                    sh """
                        ${env.COMPOSE} --profile deploy stop web-${active} || true
                        ${env.COMPOSE} --profile deploy rm -f web-${active} || true
                    """
                    echo "✓ Stopped and removed web-${active}"
                }
            }
        }
    }

    post {
        success {
            echo "✅ Blue-Green deploy complete. Active slot: ${env.INACTIVE}"
        }
        failure {
            script {
                def inactive = env.INACTIVE
                sh """
                    ${env.COMPOSE} --profile deploy stop web-${inactive} 2>/dev/null || true
                    ${env.COMPOSE} --profile deploy rm -f web-${inactive} 2>/dev/null || true
                """
                echo "❌ Deploy failed — cleaned up web-${inactive}"
            }
        }
    }
}
