SPRING_PROFILES_ACTIVE=prod

# ── 필수: 호스트의 프로젝트 절대경로 (Jenkins가 docker 명령에 사용) ──
# 예) macOS: HOST_PROJECT_PATH=/Users/jky/workspace/_jkypch.com
# 예) Linux: HOST_PROJECT_PATH=/home/user/jkypch.com
HOST_PROJECT_PATH=/Users/jky/workspace/_jkypch.com

# Jenkins
JENKINS_ADMIN_PASSWORD=admin

# Oracle (외부 연결 시 설정)
ORACLE_URL=
ORACLE_USER=
ORACLE_PASS=
